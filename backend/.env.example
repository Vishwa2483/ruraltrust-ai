# Copy this file to .env and fill in your values
# NEVER commit .env to git

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ruraltrust

# JWT Secret - use a long random string in production
JWT_SECRET=change-this-to-a-random-secret-string

# JWT Token expiry
JWT_EXPIRY_CITIZEN=24h
JWT_EXPIRY_GOVERNMENT=8h
JWT_EXPIRY_ADMIN=2h

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=5

# Admin credentials (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Port (Render sets this automatically in production)
PORT=5000
