{
    "name": "ruraltrust-ai-desktop",
    "version": "1.0.0",
    "description": "RuralTrust AI - Intelligent Rural Complaint Management System (Desktop)",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
        "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable"
    },
    "keywords": [
        "ruraltrust",
        "ai",
        "governance",
        "rural",
        "complaints"
    ],
    "author": "RuralTrust AI Team",
    "license": "MIT",
    "dependencies": {
        "electron-is-dev": "^2.0.0"
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "electron": "^28.2.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.ruraltrust.ai",
        "productName": "RuralTrust AI",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "main.js",
            "preload.js",
            "assets/**",
            "node_modules/**"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png",
            "signAndEditExecutable": false
        }
    }
}